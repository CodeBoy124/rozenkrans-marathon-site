---
import BaseLayout from "../layouts/BaseLayout.astro";
import BaseImage from "../components/BaseImage.astro";
import ArticleList from "../components/ArticleList.astro";
import SeparationBar from "../components/SeparationBar.astro";
import * as NL_HOME_PAGE_MD from "../content/nl/index.md";
import * as EN_HOME_PAGE_MD from "../content/en/index.md";
import { getCollection } from "astro:content";
import {HomePageSchema} from "../content.config";
import { i18n, i18nContent, getLocale } from "../translations/i18n";
import { getPosts } from "../util/posts";

const MD = i18nContent({nl: NL_HOME_PAGE_MD, en: EN_HOME_PAGE_MD});
const frontmatter = HomePageSchema.parse(MD.frontmatter);

const all_posts = await getPosts();
const post_list = all_posts.filter(post => (post.params.lang == getLocale())).map(post => ({post: post.props.post, slug: post.params.slug}));
post_list.sort((a, b) => b.post.data.created_at.getTime() - a.post.data.created_at.getTime());
const featured_posts = post_list.slice(0, 2);

---

<BaseLayout seo={frontmatter.seo}>
	<BaseImage src={frontmatter.image} alt="" $class="aspect-video" />
	<article id="main" class="prose text-center max-w-none" set:html={MD.compiledContent()}></article>
	<SeparationBar />
	<ArticleList title={i18n().pageStart.recent_posts} articles={featured_posts} />
</BaseLayout>