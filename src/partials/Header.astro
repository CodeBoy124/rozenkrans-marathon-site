---
import pageconfig from "../pageconfig.json"
import logo from "../assets/rmw-icon-transparent.png";
---

<script src="../scripts/collapsable.ts"></script>

<div class:list={["bg-primary", "sticky", "top-0", "z-50", "shadow-sm/25"]}>
    <header class:list={["py-base", "px-content", "flex", "flex-col", "gap-base", "w-full", "max-w-page", "m-auto"]}>
        <div class:list={["flex", "justify-between", "items-center", "text-white"]}>
            <a href={pageconfig.sitelocatie} class:list={["flex", "items-center", "gap-inner"]}>
                <img src={logo.src} alt="Rozenkrans marathon logo" class:list={["h-12.5"]} />
                <h1>Rozenkrans<br />Marathon</h1>
            </a>
            <button aria-label="toggle navbar" collapse-src="header">
                <!-- ic:baseline-menu -->
                <svg collapse-target="header" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M3 18h18v-2H3zm0-5h18v-2H3zm0-7v2h18V6z"/></svg>

                <!-- ic:baseline-close -->
                <svg collapse-target="header" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12z"/></svg>
            </button>
        </div>
    </header>
    <div collapse-target="header" class:list={["hidden", "absolute", "left-0", "top-full", "w-full"]}>
        <div class:list={["bg-primary", "w-full"]}>
            <nav class:list={["m-auto", "w-page", "max-w-full", "pb-base", "px-content"]}>
                <ul class:list={["list-disc", "list-inside", "text-screen"]}>
                    <li><a href={pageconfig.sitelocatie + "post/"}>Posts</a></li>
                    <li><a href={pageconfig.sitelocatie + "upcomming-event"}>Komend evenement</a></li>
                    <li><a href={pageconfig.sitelocatie + "faq"}>FAQ</a></li>
                </ul>
            </nav>
        </div>
        <button collapse-src="header" class:list={["bg-black", "opacity-50", "h-screen", "w-full"]} aria-label="Sluit menu"></button>
    </div>
</div>