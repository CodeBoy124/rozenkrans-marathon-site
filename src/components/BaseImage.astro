---
import { Image } from "astro:assets";
import { twMerge, type ClassNameValue } from "tailwind-merge";

interface Props {
    src: ImageMetadata|string;
    alt: string;
    showShadow?: boolean;
    loading?: "eager"|"lazy";
    $class?: ClassNameValue;
}

const {src, alt, showShadow = true, loading = null, $class} = Astro.props;

---

{(typeof(src) == "string") ? (
    <img src={src} alt={alt} loading={loading} class={twMerge("w-full object-cover rounded-base", showShadow && "shadow-md/25", $class)}/>
) : (
    <Image src={src} alt={alt} loading={loading} class={twMerge("w-full object-cover rounded-base", showShadow && "shadow-md/25", $class)}/>
)}

