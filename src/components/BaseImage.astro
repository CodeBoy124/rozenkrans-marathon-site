---
import { Image } from "astro:assets";
import clsx from "clsx";

interface Props {
    src: ImageMetadata|string;
    alt: string;
    showShadow?: boolean;
    classes?: string[];
    loading?: "eager"|"lazy";
}

const {src, alt, classes = [], showShadow = true, loading = null} = Astro.props;

---

{(typeof(src) == "string") ? (
    <img src={src} alt={alt} loading={loading} class:list={clsx("w-full", "object-cover", "rounded-base", (showShadow ? "shadow-md/25" : null), ...classes)}/>
) : (
    <Image src={src} alt={alt} loading={loading} class:list={clsx("w-full", "object-cover", "rounded-base", (showShadow ? "shadow-md/25" : null), ...classes)}/>
)}

