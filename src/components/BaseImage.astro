---
import { Image } from "astro:assets";
import { twMerge, type ClassNameValue } from "tailwind-merge";

const variant_styles = {
    noshadow: null,
    shadow: "shadow-md/25"
}

interface Props {
    variant?: 'noshadow' | 'shadow'
    src: ImageMetadata|string;
    alt?: string;
    loading?: "eager"|"lazy";
    fetchpriority?: "auto"|"high"|"low";
    $class?: ClassNameValue;
}

const {variant = 'shadow', src, alt = "", loading = null, fetchpriority=null, $class} = Astro.props;

---

{(typeof(src) == "string") ? (
    <img src={src} alt={alt} loading={loading} fetchpriority={fetchpriority} class={twMerge("w-full object-cover rounded-base", variant_styles[variant], $class)}/>
) : (
    <Image src={src} alt={alt} loading={loading} fetchpriority={fetchpriority} class={twMerge("w-full object-cover rounded-base", variant_styles[variant], $class)}/>
)}

