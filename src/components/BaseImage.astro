---
import { Image } from "astro:assets";
import {clsList} from "../util/classes";

interface Props {
    src: ImageMetadata;
    alt: string;
    showShadow?: boolean;
    classes?: string[];
}

const {src, alt, classes = [], showShadow = true} = Astro.props;

---
<Image src={src} alt={alt} class:list={clsList("w-full", "object-fill", "rounded-base", (showShadow ? "shadow-md/25" : null), ...classes)}/>
