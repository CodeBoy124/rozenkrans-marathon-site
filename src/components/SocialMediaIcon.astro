---
import { Icon } from "astro-icon/components";

interface Props {
    href: string;
    iconId: string;
    classes?: string[];
}

const {href, iconId, classes = []} = Astro.props;

---

<a href={href}>
    <div class:list={["shadow-sm/25", "w-12", "h-12", "flex", "justify-center", "items-center", "rounded-full", ...classes]}>
        <Icon name={iconId} size={38} />
    </div>
</a>