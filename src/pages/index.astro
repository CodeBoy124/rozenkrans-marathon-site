---
import BaseLayout from "../layouts/BaseLayout.astro";
import BaseImage from "../components/BaseImage.astro";
import ArticleList from "../components/ArticleList.astro";
import SeparationBar from "../components/SeparationBar.astro";
import * as HOME_PAGE_MD from "../content/index.md";
import { getCollection } from "astro:content";
import {HomePageSchema} from "../content.config";
import { i18n } from "../translations/i18n";

const frontmatter = HomePageSchema.parse(HOME_PAGE_MD.frontmatter);

const post_list = await getCollection('posts');
post_list.sort((a, b) => b.data.created_at.getTime() - a.data.created_at.getTime());
const featured_posts = post_list.slice(0, 2);

---

<BaseLayout>
	<BaseImage src={frontmatter.image} alt="" $class="aspect-video" />
	<article id="main" class="prose text-center max-w-none" set:html={HOME_PAGE_MD.compiledContent()}></article>
	<SeparationBar />
	<ArticleList title={i18n().pageStart.recent_posts} articles={featured_posts} />
</BaseLayout>