---
import pageconfig from "../pageconfig.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import FaqResponseAnswer from "../components/FaqResponseAnswer.svelte";
import SeparationBar from "../components/SeparationBar.astro";
import * as faq_md from "../content/faq.md";
---

<BaseLayout title={pageconfig.sitetitel + " | FAQ"}>
    <article class="prose text-center max-w-none">
		<Fragment set:html={faq_md.compiledContent()} />
	</article>
    <div class:list={["flex", "flex-col", "gap-content"]}>
        {faq_md.frontmatter.items.map((item: {vraag: string, antwoord: string}) => (
            <FaqResponseAnswer question={item.vraag} answer={item.antwoord} client:load />
        ))}
    </div>
</BaseLayout>