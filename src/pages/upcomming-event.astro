---
import PAGECONFIG_JSON from "../pageconfig.json";
import * as UPCOMMING_EVENT_MD from "../content/upcomming-event.md";
import BaseLayout from "../layouts/BaseLayout.astro";
import BaseImage from "../components/BaseImage.astro";
import Button from "../components/Button.astro";
---

<BaseLayout title={PAGECONFIG_JSON.site_title + "| Komend evenement"}>
    <BaseImage src={UPCOMMING_EVENT_MD.frontmatter.cover_image} alt="Dominicaanse priester met Rozenkrans in zijn handen" $class="aspect-video" />
	<article class="prose text-center max-w-none" set:html={UPCOMMING_EVENT_MD.compiledContent()}></article>
    <a href={UPCOMMING_EVENT_MD.frontmatter.signup_url}>
        <Button variant="light_fill" $class="w-full">Meld je aan!</Button>
    </a>
</BaseLayout>